{
    "version": 2,
    "framework": null,
    "functions": {
        "index.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|favicon.ico|mix-manifest.json)/(.*)",
            "dest": "/public/$1/$2",
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}